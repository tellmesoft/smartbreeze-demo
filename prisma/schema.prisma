generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  ADMINISTRADOR
  TECNICO
  ENCARGADO
}

enum EstadoEquipo {
  OPERATIVO
  MANTENIMIENTO
  FALLA
  FUERA_SERVICIO
}

enum TipoEquipo {
  SPLIT
  MANEJADORA
  CHILLER
  FAN_COIL
  EXTRACTOR
  TORRE_ENFRIAMIENTO
  BOMBA
  OTRO
}

enum EstadoMantenimiento {
  PENDIENTE
  EN_PROGRESO
  EN_ESPERA
  COMPLETADO
}

enum Prioridad {
  BAJA
  MEDIA
  ALTA
}

enum EstadoAlerta {
  ABIERTA
  EN_REVISION
  RESUELTA
}

enum TipoRepuesto {
  FILTRO
  REFRIGERANTE
  CONTROL
  MOTOR
  ELECTRICO
  OTRO
}

enum TipoMovimientoRepuesto {
  ENTRADA
  SALIDA
  AJUSTE
  PEDIDO
}

enum ResultadoInspeccion {
  PASS
  FLAG
  FAIL
}

enum UnidadMedidor {
  HORAS
  KWH
  PSI
  AMPERIOS
  CELSIUS
  DELTA_T
}

enum FrecuenciaLectura {
  DIARIA
  SEMANAL
  MENSUAL
}

enum TipoProveedor {
  REPUESTOS
  REFRIGERANTE
  SERVICIO_TECNICO
  CONTRATISTA
}

model Usuario {
  id             String          @id @default(cuid())
  nombre         String
  email          String          @unique
  password       String
  rol            Rol
  avatarBase64   String?         @map("avatar_base64")
  ultimaVisita   DateTime        @default(now()) @map("ultima_visita")
  equipos        Equipo[]        @relation("TecnicoAsignado")
  mantenimientos Mantenimiento[] @relation("TecnicoMantenimiento")
  mantenimientosCreados Mantenimiento[] @relation("MantenimientoCreador")
  historialEstadosMantenimiento HistorialEstadoMantenimiento[] @relation("HistorialEstadoMantenimientoUsuario")
  historialEstadosAlerta HistorialEstadoAlerta[] @relation("HistorialEstadoAlertaUsuario")
  alertas        Alerta[]        @relation("ReportadoPor")
  procedimientos Procedimiento[] @relation("ProcedimientoCreador")
  proveedores    Proveedor[]     @relation("ProveedorCreador")
  movimientosRepuesto MovimientoRepuesto[] @relation("MovimientoRepuestoRegistrador")

  @@map("usuarios")
}

model Ubicacion {
  id          String   @id @default(cuid())
  nombre      String
  sector      String?
  facultad    String
  edificio    String
  piso        String?
  direccion   String?
  descripcion String?
  fotoBase64  String?  @map("foto_base64")
  equipos     Equipo[]

  @@map("ubicaciones")
}

model Equipo {
  id                    String           @id @default(cuid())
  codigoInterno         String           @unique @map("codigo_interno")
  codigoQr              String           @unique @map("codigo_qr")
  nombre                String
  marca                 String
  modelo                String
  serie                 String
  btu                   Int?
  refrigerante          String?
  tipoEquipo            TipoEquipo       @default(OTRO) @map("tipo_equipo")
  fechaInstalacion      DateTime?        @map("fecha_instalacion")
  ultimaMantenimiento   DateTime?        @map("ultima_mantenimiento")
  proximaMantenimiento  DateTime?        @map("proxima_mantenimiento")
  estado                EstadoEquipo     @default(OPERATIVO)
  descripcion           String?
  manualUrl             String?          @map("manual_url")
  fotoBase64            String?          @map("foto_base64")
  qrBase64              String?          @map("qr_base64")
  ubicacionId           String           @map("ubicacion_id")
  tecnicoId             String?          @map("tecnico_id")
  ubicacion             Ubicacion        @relation(fields: [ubicacionId], references: [id])
  tecnico               Usuario?         @relation("TecnicoAsignado", fields: [tecnicoId], references: [id])
  mantenimientos        Mantenimiento[]
  alertas               Alerta[]
  repuestos             Repuesto[]
  medidores             Medidor[]
  createdAt             DateTime         @default(now()) @map("created_at")

  @@map("equipos")
}

model Mantenimiento {
  id                    String                 @id @default(cuid())
  titulo                String
  equipoId              String                 @map("equipo_id")
  tecnicoId             String                 @map("tecnico_id")
  creadoPorId           String?                @map("creado_por_id")
  fechaProgramada       DateTime               @map("fecha_programada")
  fechaRealizada        DateTime?              @map("fecha_realizada")
  horasTrabajadas       Float?                 @map("horas_trabajadas")
  observaciones         String?
  estadoGeneral         String?                @map("estado_general")
  proximaMantenimiento  DateTime?              @map("proxima_mantenimiento")
  estado                EstadoMantenimiento    @default(PENDIENTE)
  prioridad             Prioridad              @default(MEDIA)
  recurrencia           String?
  procedimientoId       String?                    @map("procedimiento_id")
  proveedorId           String?                    @map("proveedor_id")
  resultadoInspeccion   ResultadoInspeccion?       @map("resultado_inspeccion")
  firmaSupervisorBase64 String?                    @map("firma_supervisor_base64")
  equipo                Equipo                     @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  tecnico               Usuario                    @relation("TecnicoMantenimiento", fields: [tecnicoId], references: [id])
  creadoPor             Usuario?                   @relation("MantenimientoCreador", fields: [creadoPorId], references: [id], onDelete: SetNull)
  procedimiento         Procedimiento?             @relation(fields: [procedimientoId], references: [id], onDelete: SetNull)
  proveedor             Proveedor?                 @relation(fields: [proveedorId], references: [id], onDelete: SetNull)
  parametrosHvac        ParametrosHvac?
  esterilizacion        Esterilizacion?
  evidencia             EvidenciaMantenimiento?
  respuestasProcedimiento ProcedimientoItemRespuesta[]
  historialEstados      HistorialEstadoMantenimiento[]

  @@map("mantenimientos")
}

model HistorialEstadoMantenimiento {
  id              String                 @id @default(cuid())
  mantenimientoId String                 @map("mantenimiento_id")
  estadoAnterior  EstadoMantenimiento?   @map("estado_anterior")
  estadoNuevo     EstadoMantenimiento    @map("estado_nuevo")
  cambiadoPorId   String                 @map("cambiado_por_id")
  fecha           DateTime               @default(now())
  mantenimiento   Mantenimiento          @relation(fields: [mantenimientoId], references: [id], onDelete: Cascade)
  cambiadoPor     Usuario                @relation("HistorialEstadoMantenimientoUsuario", fields: [cambiadoPorId], references: [id], onDelete: Restrict)

  @@map("historial_estado_mantenimiento")
}

model ParametrosHvac {
  id                   String        @id @default(cuid())
  mantenimientoId      String        @unique @map("mantenimiento_id")
  voltaje              Float?
  amperaje             Float?
  presionBaja          Float?        @map("presion_baja")
  presionAlta          Float?        @map("presion_alta")
  temperaturaRetorno   Float?        @map("temperatura_retorno")
  temperaturaImpulsion Float?        @map("temperatura_impulsion")
  temperaturaAmbiente  Float?        @map("temperatura_ambiente")
  subenfriamiento      Float?
  sobrecalentamiento   Float?
  mantenimiento        Mantenimiento @relation(fields: [mantenimientoId], references: [id], onDelete: Cascade)

  @@map("parametros_hvac")
}

model Esterilizacion {
  id              String        @id @default(cuid())
  mantenimientoId String        @unique @map("mantenimiento_id")
  aplicada        Boolean       @default(false)
  metodo          String?
  horasExposicion Float?        @map("horas_exposicion")
  observaciones   String?
  mantenimiento   Mantenimiento @relation(fields: [mantenimientoId], references: [id], onDelete: Cascade)

  @@map("esterilizaciones")
}

model EvidenciaMantenimiento {
  id                 String        @id @default(cuid())
  mantenimientoId    String        @unique @map("mantenimiento_id")
  fotoAntesBase64    String?       @map("foto_antes_base64")
  fotoDespuesBase64  String?       @map("foto_despues_base64")
  firmaClienteBase64 String?       @map("firma_cliente_base64")
  pdfGeneradoBase64  String?       @map("pdf_generado_base64")
  mantenimiento      Mantenimiento @relation(fields: [mantenimientoId], references: [id], onDelete: Cascade)

  @@map("evidencias_mantenimiento")
}

model Alerta {
  id           String       @id @default(cuid())
  equipoId     String       @map("equipo_id")
  reportadoPor String       @map("reportado_por")
  descripcion  String
  prioridad    Prioridad    @default(MEDIA)
  estado       EstadoAlerta @default(ABIERTA)
  fecha        DateTime     @default(now())
  equipo       Equipo       @relation(fields: [equipoId], references: [id])
  usuario      Usuario      @relation("ReportadoPor", fields: [reportadoPor], references: [id])
  historialEstados HistorialEstadoAlerta[]

  @@map("alertas")
}

model HistorialEstadoAlerta {
  id             String        @id @default(cuid())
  alertaId       String        @map("alerta_id")
  estadoAnterior EstadoAlerta? @map("estado_anterior")
  estadoNuevo    EstadoAlerta  @map("estado_nuevo")
  cambiadoPorId  String        @map("cambiado_por_id")
  fecha          DateTime      @default(now())
  alerta         Alerta        @relation(fields: [alertaId], references: [id], onDelete: Cascade)
  cambiadoPor    Usuario       @relation("HistorialEstadoAlertaUsuario", fields: [cambiadoPorId], references: [id], onDelete: Restrict)

  @@map("historial_estado_alerta")
}

model Repuesto {
  id                 String                 @id @default(cuid())
  codigoInterno      String                 @unique @map("codigo_interno")
  nombre             String
  descripcion        String?
  tipo               TipoRepuesto           @default(OTRO)
  cantidadDisponible Int                    @default(0) @map("cantidad_disponible")
  cantidadMinima     Int                    @default(1) @map("cantidad_minima")
  cantidadPedida     Int                    @default(0) @map("cantidad_pedida")
  costoUnitario      Float?                 @map("costo_unitario")
  proveedorId        String?                @map("proveedor_id")
  ubicacionAlmacen   String?                @map("ubicacion_almacen")
  fotoBase64         String?                @map("foto_base64")
  qrBase64           String?                @map("qr_base64")
  equipoId           String?                @map("equipo_id")
  equipo             Equipo?                @relation(fields: [equipoId], references: [id], onDelete: SetNull)
  proveedor          Proveedor?             @relation(fields: [proveedorId], references: [id], onDelete: SetNull)
  movimientos        MovimientoRepuesto[]
  createdAt          DateTime               @default(now()) @map("created_at")

  @@map("repuestos")
}

model MovimientoRepuesto {
  id                 String                 @id @default(cuid())
  repuestoId         String                 @map("repuesto_id")
  tipo               TipoMovimientoRepuesto
  cantidad           Int
  cantidadResultante Int                    @map("cantidad_resultante")
  observaciones      String?
  registradoPorId    String?                @map("registrado_por_id")
  fecha              DateTime               @default(now())
  repuesto           Repuesto               @relation(fields: [repuestoId], references: [id], onDelete: Cascade)
  registradoPor      Usuario?               @relation("MovimientoRepuestoRegistrador", fields: [registradoPorId], references: [id], onDelete: SetNull)

  @@map("movimientos_repuesto")
}

model Procedimiento {
  id             String              @id @default(cuid())
  titulo         String
  descripcion    String?
  tipoEquipo     TipoEquipo?         @map("tipo_equipo")
  creadoPorId    String?             @map("creado_por_id")
  creadoPor      Usuario?            @relation("ProcedimientoCreador", fields: [creadoPorId], references: [id], onDelete: SetNull)
  items          ProcedimientoItem[]
  mantenimientos Mantenimiento[]
  createdAt      DateTime            @default(now()) @map("created_at")

  @@map("procedimientos")
}

model ProcedimientoItem {
  id              String                       @id @default(cuid())
  procedimientoId String                       @map("procedimiento_id")
  orden           Int
  seccion         String?
  titulo          String
  procedimiento   Procedimiento                @relation(fields: [procedimientoId], references: [id], onDelete: Cascade)
  respuestas      ProcedimientoItemRespuesta[]

  @@map("procedimiento_items")
}

model ProcedimientoItemRespuesta {
  mantenimientoId     String            @map("mantenimiento_id")
  procedimientoItemId String            @map("procedimiento_item_id")
  completado          Boolean           @default(false)
  mantenimiento       Mantenimiento     @relation(fields: [mantenimientoId], references: [id], onDelete: Cascade)
  item                ProcedimientoItem @relation(fields: [procedimientoItemId], references: [id], onDelete: Cascade)

  @@id([mantenimientoId, procedimientoItemId])
  @@map("procedimiento_item_respuestas")
}

model Medidor {
  id               String            @id @default(cuid())
  nombre             String
  unidad             UnidadMedidor
  frecuencia         FrecuenciaLectura @default(SEMANAL)
  ultimaLectura      Float?            @map("ultima_lectura")
  ultimaLecturaAt    DateTime?         @map("ultima_lectura_at")
  proximaLecturaAt   DateTime?         @map("proxima_lectura_at")
  equipoId           String            @map("equipo_id")
  equipo             Equipo            @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  lecturas           LecturaMedidor[]
  createdAt          DateTime          @default(now()) @map("created_at")

  @@map("medidores")
}

model LecturaMedidor {
  id            String   @id @default(cuid())
  medidorId     String   @map("medidor_id")
  valor         Float
  fecha         DateTime @default(now())
  observaciones String?
  medidor       Medidor  @relation(fields: [medidorId], references: [id], onDelete: Cascade)

  @@map("lecturas_medidor")
}

model Proveedor {
  id             String         @id @default(cuid())
  nombre         String
  descripcion    String?
  tipo           TipoProveedor  @default(REPUESTOS)
  email          String?
  telefono       String?
  creadoPorId    String?        @map("creado_por_id")
  creadoPor      Usuario?       @relation("ProveedorCreador", fields: [creadoPorId], references: [id], onDelete: SetNull)
  repuestos      Repuesto[]
  mantenimientos Mantenimiento[]
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("proveedores")
}

model ConfiguracionApp {
  id                   String   @id @default("default")
  stockMinimoRepuestos Int      @default(3) @map("stock_minimo_repuestos")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("configuracion_app")
}
